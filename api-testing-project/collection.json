{
  "info": {
    "_postman_id": "cd5fbaf4-13f8-4531-90f2-dad5f46e9e7f",
    "name": "Projet 1 - API Testing Reqres",
    "description": "Collection Postman pour démontrer des compétences QA API (positif + négatif).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET users (page 2)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users?page=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "2"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time is below 2000ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('data is an array', function () {",
              "  pm.expect(body.data).to.be.an('array');",
              "});",
              "",
              "pm.test('first user has id and email', function () {",
              "  pm.expect(body.data[0]).to.have.property('id');",
              "  pm.expect(body.data[0]).to.have.property('email');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
