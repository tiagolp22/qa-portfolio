{
  "info": {
    "_postman_id": "cd5fbaf4-13f8-4531-90f2-dad5f46e9e7f",
    "name": "Projet 1 - API Testing Reqres",
    "description": "Collection Postman pour démontrer des compétences QA API (positif + négatif).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET users (page 2)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users?page=2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ],
          "query": [
            {
              "key": "page",
              "value": "2"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time is below 2000ms', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('data is an array', function () {",
              "  pm.expect(body.data).to.be.an('array');",
              "});",
              "",
              "pm.test('first user has id and email', function () {",
              "  pm.expect(body.data[0]).to.have.property('id');",
              "  pm.expect(body.data[0]).to.have.property('email');",
              "});",
              "",
              "const usersListSchema = {",
              "  type: 'object',",
              "  required: ['page', 'per_page', 'total', 'total_pages', 'data'],",
              "  properties: {",
              "    page: { type: 'integer' },",
              "    per_page: { type: 'integer' },",
              "    total: { type: 'integer' },",
              "    total_pages: { type: 'integer' },",
              "    data: {",
              "      type: 'array',",
              "      minItems: 1,",
              "      items: {",
              "        type: 'object',",
              "        required: ['id', 'email', 'first_name', 'last_name', 'avatar'],",
              "        properties: {",
              "          id: { type: 'integer' },",
              "          email: { type: 'string' },",
              "          first_name: { type: 'string' },",
              "          last_name: { type: 'string' },",
              "          avatar: { type: 'string' }",
              "        }",
              "      }",
              "    }",
              "  }",
              "};",
              "",
              "pm.test('Response matches users list JSON schema', function () {",
              "  pm.response.to.have.jsonSchema(usersListSchema);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Tiago\",\n  \"job\": \"QA Analyst\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "",
              "pm.test('Not an auth/API key error', function () {",
              "  pm.expect(body.error, `API returned error: ${body.error}`).to.not.eql('missing_api_key');",
              "});",
              "",
              "pm.test('Status code is 201 when user is created', function () {",
              "  if (!body.error) {",
              "    pm.response.to.have.status(201);",
              "  }",
              "});",
              "",
              "if (!body.error) {",
              "  pm.test('Response has id and createdAt', function () {",
              "    pm.expect(body).to.have.property('id');",
              "    pm.expect(body).to.have.property('createdAt');",
              "  });",
              "",
              "  const createUserSchema = {",
              "    type: 'object',",
              "    required: ['name', 'job', 'id', 'createdAt'],",
              "    properties: {",
              "      name: { type: 'string' },",
              "      job: { type: 'string' },",
              "      id: { type: 'string' },",
              "      createdAt: { type: 'string' }",
              "    }",
              "  };",
              "",
              "  pm.test('Response matches create user JSON schema', function () {",
              "    pm.response.to.have.jsonSchema(createUserSchema);",
              "  });",
              "}"
            ]
          }
        }
      ]
    },
